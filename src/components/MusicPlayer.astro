---
const { name, file } = Astro.props;
---

<div class="player">
  <audio id="player-audio" src={file}></audio>
  <div class="progress-bar-container" id="player-progress-container">
    <div class="progress-bar" id="player-progress-bar"></div>
    <div class="progress-cursor" id="player-progress-cursor"></div>
  </div>
  <div class="controls">
    <button id="player-play">▶ Play</button>
    <button id="player-pause">⏸ Pause</button>
  </div>
</div>

<style>
  .player {
    background: #d4c4a0;
    border: 1px solid #a08050;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
    border-radius: 10px;
    max-width: 500px;
  }
  .controls {
    margin-top: 0.75rem;
    display: flex;
    gap: 0.5rem;
  }
  button {
    cursor: pointer;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 0.9rem;
    padding: 0.4rem 1.1rem;
    border: 1px solid #a08050;
    border-radius: 5px;
    background: #c0a878;
    color: #6c5030;
    font-weight: 600;
    transition: background 0.2s, border-color 0.2s;
  }
  button:hover {
    background: #a08050;
    color: #e8dcc8;
    border-color: #6c5030;
  }
  .progress-bar-container {
    width: 100%;
    height: 8px;
    background: #e8dcc8;
    border-radius: 5px;
    margin: 0.75rem 0 0.25rem;
    cursor: pointer;
    position: relative;
  }
  .progress-bar {
    height: 100%;
    background: #a08050;
    border-radius: 5px;
    width: 0%;
    transition: width 0.1s linear;
  }
  .progress-cursor {
    position: absolute;
    top: -4px;
    left: 0%;
    width: 16px;
    height: 16px;
    background: #6c5030;
    border-radius: 50%;
    transform: translateX(-50%);
    pointer-events: none;
  }
</style>

<script>
  const audio = document.getElementById('player-audio') as HTMLAudioElement;
  const progressBar = document.getElementById('player-progress-bar') as HTMLElement;
  const progressContainer = document.getElementById('player-progress-container') as HTMLElement;
  const progressCursor = document.getElementById('player-progress-cursor') as HTMLElement;
  const playBtn = document.getElementById('player-play') as HTMLButtonElement;
  const pauseBtn = document.getElementById('player-pause') as HTMLButtonElement;

  function updateProgress() {
    if (audio.duration) {
      const percent = (audio.currentTime / audio.duration) * 100;
      progressBar.style.width = percent + '%';
      progressCursor.style.left = percent + '%';
    }
  }

  audio.addEventListener('timeupdate', updateProgress);
  audio.addEventListener('loadedmetadata', updateProgress);

  progressContainer.addEventListener('click', (e) => {
    const rect = progressContainer.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const percent = x / rect.width;
    audio.currentTime = percent * audio.duration;
  });

  playBtn.addEventListener('click', () => audio.play());
  pauseBtn.addEventListener('click', () => audio.pause());
</script>
